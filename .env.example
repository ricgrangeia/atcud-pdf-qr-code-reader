# HTTP server port
PORT=8080

# vLLM backend — available for AI-assisted processing (future use)
VLLM_BASE_URL=http://vllm:8000/v1
VLLM_API_KEY=your-vllm-api-key
VLLM_MODEL=Qwen/Qwen2.5-7B-Instruct-AWQ

# Docker network that the app and Traefik share
PROXY_NETWORK_NAME=proxy-network
AI_NETWORK_NAME=ai-network

# URL Host Domain
URL_HOST_DOMAIN=qrcode.example.com

# Running in "debug" mode. Switch to "release" mode in production.
GIN_MODE=debug

TOOL_SERVER_URL=http://localaiapi:8000
TOOL_SERVER_API_KEY=insert API Key